<ul class="card-text font-weight-light list-group list-group-flush">
  {% assign semesters = "Spring,Summer,Fall,Winter" | split: "," %}
  {% assign sorted_teaching = "" | split: "" %}

  {% for course in site.data.resume.teaching %}
    {% assign semester_index = semesters | index_of: course.Semester %}
    {% assign sortable_date = course.Year | append: semester_index | plus: 0 %}
    {% assign course = course | merge: sortable_date %}
    {% assign sorted_teaching = sorted_teaching | push: course %}
  {% endfor %}
  
  {% assign sorted_teaching = sorted_teaching | sort: 'sortable_date' | reverse %}

  {% for content in sorted_teaching %}
    <li class="list-group-item">
      <div class="row">
        <div class="col-xs-2 cl-sm-2 col-md-2 text-center" style="width: 75px">
          {% if content.Date %}
            {% assign date = content.Date %}
          {% else %}
            {% assign date = '' %}
          {% endif %}
          <table class="table-cv">
            <tbody>
              <tr>
                <td>
                  <span class="badge font-weight-bold danger-color-dark align-middle" style="min-width: 75px"> {{ date }} </span>
                </td>
              </tr>
              {% if content.location %}
                <tr>
                  <td>
                    <p class="location">
                      <i class="fa-solid fa-location-dot iconlocation"></i>
                      {{ content.location }}
                    </p>
                  </td>
                </tr>
              {% endif %}
            </tbody>
          </table>
        </div>
        <div class="col-xs-10 cl-sm-10 col-md-10 mt-2 mt-md-0">
          <h6 class="title font-weight-bold ml-1 ml-md-4">
            <a href="{{ content.url }}">{{ content.position }}</a>
          </h6>
          <h6 class="ml-1 ml-md-4" style="font-size: 0.95rem">{{ content.name }}</h6>
          <h6 class="ml-1 ml-md-4" style="font-size: 0.95rem; font-style: italic">{{ content.summary }}</h6>
          <ul class="items">
            {% for item in content.highlights %}
              <li>
                <span class="item">{{ item }}</span>
              </li>
            {% endfor %}
          </ul>
        </div>
      </div>
    </li>
  {% endfor %}
</ul>
